{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "cmake -S . -B build -G Ninja && cmake --build build",
            "group": {
                "kind": "build",
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "clear": true,
                "reveal": "always"
            }
        },
        {
            "label": "Run project",
            "type": "shell",
            "command": "./bin/hello",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "Clean Build Folder",
            "type": "shell",
            "command": "rm -rf build bin && echo 'Build and bin folders cleared'",
            "group": "build",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        },
        {
            "label": "Run Cppcheck",
            "type": "shell",
            "command": "cppcheck",
            "args": [
                "--inline-suppr",
                "--project=build/compile_commands.json",
                "--check-level=normal",
                "--enable=warning,style",
                "--template={file}:{line}:{severity}:{id}:{message}"
            ],
            "dependsOn": ["Build Project"],
            "group": "build"
        },
        {
            "label": "Run Clang-Tidy",
            "type": "shell",
            //removed /* --fix-errors */
            "command": "clang-tidy -p build/  src/*.cpp",
            "group": "build",
            "dependsOn": ["Build Project"],
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "clear": true
            }
        },
        {
            "label": "Clang-Format All",
            "type": "shell",
            "command": "find src include tests -name '*.[ch]' -o -name '*.cpp' | xargs -r clang-format -i -style=file",
            "group": "build",
            "presentation": {
                "reveal": "silent",
                "clear": true
            }
        },
        {
            "label": "BUILD & RUN TESTS",
            "type": "shell",
            "command": "cmake -S . -B build -DBUILD_TESTS=ON -G Ninja && cmake --build build && ./bin/unit_tests",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}